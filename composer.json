{
    "name": "callcocam/laravel-whatsapp-cloud",
    "description": "Núcleo reutilizável da WhatsApp Cloud API (Meta) para Laravel: envio de templates/sessão/interativo por-tenant, webhook com assinatura e eventos, e gestão de templates via Artisan.",
    "keywords": ["laravel", "whatsapp", "whatsapp-cloud-api", "meta", "messaging"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Claudio Campos",
            "email": "callcocam@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "inertiajs/inertia-laravel": "^1.3 || ^2.0",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.20"
    },
    "suggest": {
        "inertiajs/inertia-laravel": "Enables the template-management web panel (Inertia + Vue). Publish its Vue pages with `vendor:publish --tag=whatsapp-cloud-inertia`."
    },
    "autoload": {
        "psr-4": {
            "Callcocam\\WhatsAppCloud\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Callcocam\\WhatsAppCloud\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --parallel",
        "test:lint": "pint --parallel --test",
        "test:types": "phpstan analyse",
        "test:unit": "pest",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Callcocam\\WhatsAppCloud\\WhatsAppCloudServiceProvider"
            ],
            "aliases": {
                "WhatsApp": "Callcocam\\WhatsAppCloud\\Facades\\WhatsApp"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
